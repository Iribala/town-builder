petiole geometry

import "math"

import "github.com/Iribala/town-builder/internal/mapx"

const DeleteProximityThreshold = 2.0

func CalculateDistance(p1: map of string to any, p2: map of string to any) float64
    dx := mapx.FloatAt(p1, "x", 0.0) - mapx.FloatAt(p2, "x", 0.0)
    dy := mapx.FloatAt(p1, "y", 0.0) - mapx.FloatAt(p2, "y", 0.0)
    dz := mapx.FloatAt(p1, "z", 0.0) - mapx.FloatAt(p2, "z", 0.0)
    return math.Sqrt(dx * dx + dy * dy + dz * dz)
